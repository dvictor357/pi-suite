{
  "name": "pi-suite",
  "version": "0.1.0",
  "private": true,
  "description": "Loop-engineering toolkit for pi — pi-quest (autonomous project manager), pi-todo (task ledger), and pi-memory (project/user memory), sharing one cross-extension contract.",
  "keywords": [
    "pi-package"
  ],
  "license": "MIT",
  "author": "Dimas Victor",
  "pi": {
    "extensions": [
      "./extensions"
    ]
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "prettier": "^3.3.0",
    "typescript": "^5.6.0"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  }
}
